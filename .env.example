# =============================================================================
# Divine Children Home Ltd — Environment Configuration
# =============================================================================
# Copy the relevant section to:
#   artifacts/divine-children-home/.env   (frontend)
#   artifacts/api-server/.env             (API server)
#
# Never commit real secrets. Use platform secret managers in staging/production.
# =============================================================================

# -----------------------------------------------------------------------------
# FRONTEND (artifacts/divine-children-home/.env)
# -----------------------------------------------------------------------------

# Dev server port
PORT=23337

# Base path for deployment (use / for root)
BASE_PATH=/

# API proxy target during local development
VITE_API_PROXY_TARGET=http://localhost:8080

# Production API URL (set on Vercel — no trailing slash)
# VITE_API_BASE_URL=https://api.divinechildrenhome.co.uk

# Optional monitoring (requires cookie consent)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_CLARITY_PROJECT_ID=xxxxxxxxxx
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# -----------------------------------------------------------------------------
# API SERVER (artifacts/api-server/.env)
# -----------------------------------------------------------------------------

PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated allowed origins (REQUIRED in production)
CORS_ORIGIN=http://localhost:23337

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set true when behind Railway/Render/Vercel reverse proxy
# TRUST_PROXY=true

# Admin password reset redirect
# ADMIN_RESET_PASSWORD_URL=https://www.divinechildrenhome.co.uk/admin/reset-password

# -----------------------------------------------------------------------------
# SCRIPTS (optional — create-admin)
# -----------------------------------------------------------------------------

# ADMIN_EMAIL=admin@divinechildrenhome.co.uk
# ADMIN_PASSWORD=change-me-immediately
# ADMIN_NAME=Super Admin

# -----------------------------------------------------------------------------
# STAGING EXAMPLE
# -----------------------------------------------------------------------------

# NODE_ENV=production
# CORS_ORIGIN=https://staging.divinechildrenhome.co.uk
# VITE_API_BASE_URL=https://api-staging.divinechildrenhome.co.uk

# -----------------------------------------------------------------------------
# PRODUCTION EXAMPLE
# -----------------------------------------------------------------------------

# NODE_ENV=production
# LOG_LEVEL=info
# CORS_ORIGIN=https://www.divinechildrenhome.co.uk
# TRUST_PROXY=true
# VITE_API_BASE_URL=https://api.divinechildrenhome.co.uk
