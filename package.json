{
  "name": "workspace",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm --filter @workspace/divine-children-home --filter @workspace/api-server run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --filter \"./artifacts/**\" --if-present run test",
    "test:e2e": "playwright test",
    "dev:web": "pnpm --filter @workspace/divine-children-home run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "verify:supabase": "pnpm --filter @workspace/scripts run verify-supabase"
  },
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.52.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
